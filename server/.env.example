APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgres://dfchat:changeme_postgres@localhost:5432/dfchat?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=changeme_redis
REDIS_DB=0

JWT_SECRET=dev_only_secret_replace_me_at_least_32_bytes_long_xxxxx
JWT_ACCESS_TTL_HOURS=2
JWT_REFRESH_TTL_HOURS=720

CORS_ALLOW_ORIGINS=http://localhost:5173,app://-

# MinIO (S3-compatible) object storage. For local dev the public URL is the
# same as the internal endpoint; in prod, point public_url to your CDN/Nginx.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=changeme_minio
MINIO_BUCKET=dfchat
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

